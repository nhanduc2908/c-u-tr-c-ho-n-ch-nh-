# ============================================
# Apache Configuration for Security Platform
# ============================================

# Enable rewrite engine
RewriteEngine On

# Set default character set
AddDefaultCharset UTF-8
AddDefaultCharset utf-8

# ============================================
# SECURITY HEADERS
# ============================================
<IfModule mod_headers.c>
    # Security headers
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    
    # Disable content sniffing
    Header set X-Content-Type-Options "nosniff"
</IfModule>

# ============================================
# BLOCK ACCESS TO SENSITIVE FILES
# ============================================
<FilesMatch "\.(env|log|ini|sql|bak|sh|sqlite|json|lock|md|txt)$">
    Order allow,deny
    Deny from all
    Satisfy All
</FilesMatch>

<FilesMatch "(composer\.json|composer\.lock|package\.json|phpunit\.xml|.env|.gitignore|README\.md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to hidden files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# ============================================
# PROTECT STORAGE DIRECTORY
# ============================================
<IfModule mod_rewrite.c>
    RewriteRule ^storage/ - [F,L]
</IfModule>

# ============================================
# ROUTING - Send all requests to index.php
# ============================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ index.php [QSA,L]

# ============================================
# REDIRECT TRAILING SLASHES
# ============================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1 [L,R=301]

# ============================================
# PHP SETTINGS
# ============================================
<IfModule mod_php7.c>
    php_value upload_max_filesize 50M
    php_value post_max_size 50M
    php_value max_execution_time 300
    php_value memory_limit 512M
    php_value max_input_vars 5000
    php_value date.timezone Asia/Ho_Chi_Minh
</IfModule>

<IfModule mod_php8.c>
    php_value upload_max_filesize 50M
    php_value post_max_size 50M
    php_value max_execution_time 300
    php_value memory_limit 512M
    php_value max_input_vars 5000
    php_value date.timezone Asia/Ho_Chi_Minh
</IfModule>

# ============================================
# COMPRESSION - GZIP
# ============================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml application/rss+xml
    AddOutputFilterByType DEFLATE font/ttf font/otf image/svg+xml
</IfModule>

# ============================================
# CACHING STATIC FILES
# ============================================
<FilesMatch "\.(ico|pdf|flv|jpg|jpeg|png|gif|js|css|swf)$">
    Header set Cache-Control "max-age=2592000, public"
</FilesMatch>

# ============================================
# ERROR DOCUMENTS
# ============================================
ErrorDocument 400 /error/400
ErrorDocument 401 /error/401
ErrorDocument 403 /error/403
ErrorDocument 404 /error/404
ErrorDocument 500 /error/500

# ============================================
# FORCE HTTPS (Uncomment in production)
# ============================================
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# ============================================
# PREVENT DIRECTORY LISTING
# ============================================
Options -Indexes

# ============================================
# CUSTOM LOGS
# ============================================
LogFormat "%h %l %u %t \"%r\" %>s %b \"%{Referer}i\" \"%{User-Agent}i\"" combined
LogFormat "%h %l %u %t \"%r\" %>s %b" common
