{
    "name": "security/assessment-platform",
    "description": "Security Assessment Platform with 280 criteria, 17 categories, 3 roles (Admin, Security Officer, Viewer)",
    "type": "project",
    "license": "MIT",
    "version": "3.0.0",
    "authors": [
        {
            "name": "Security Team",
            "email": "dev@security-platform.com",
            "role": "Developer"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-curl": "*",
        "ext-mbstring": "*",
        "ext-fileinfo": "*",
        "firebase/php-jwt": "^6.0",
        "monolog/monolog": "^3.0",
        "vlucas/phpdotenv": "^5.5",
        "phpmailer/phpmailer": "^6.8",
        "phpoffice/phpspreadsheet": "^1.29",
        "setasign/fpdf": "^1.8",
        "guzzlehttp/guzzle": "^7.0",
        "ramsey/uuid": "^4.7",
        "paragonie/random_compat": "^9.99",
        "symfony/console": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.7",
        "friendsofphp/php-cs-fixer": "^3.4",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "Core\\": "core/",
            "Controllers\\": "controllers/",
            "Models\\": "models/",
            "Middleware\\": "middleware/",
            "Services\\": "services/",
            "Repositories\\": "repositories/",
            "Jobs\\": "jobs/",
            "Listeners\\": "listeners/",
            "Exceptions\\": "exceptions/"
        },
        "files": [
            "core/Helper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8000 -t public",
        "serve": "php artisan serve",
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage/",
        "lint": "phpcs --standard=PSR12 src/",
        "lint-fix": "phpcbf --standard=PSR12 src/",
        "cs-fix": "php-cs-fixer fix src/",
        "migrate": "php artisan migrate",
        "migrate:rollback": "php artisan migrate:rollback",
        "seed": "php artisan db:seed",
        "fresh": "php artisan migrate:fresh --seed",
        "optimize": "php artisan optimize",
        "cache:clear": "php artisan cache:clear",
        "storage:link": "php artisan storage:link",
        "analyze": "vendor/bin/phpstan analyse src/",
        "security:check": "composer audit",
        "post-install-cmd": [
            "@optimize",
            "@cache:clear"
        ],
        "post-update-cmd": [
            "@optimize",
            "@cache:clear"
        ]
    },
    "scripts-descriptions": {
        "start": "Start development server",
        "test": "Run PHPUnit tests",
        "lint": "Check code style with PHP_CodeSniffer",
        "migrate": "Run database migrations",
        "fresh": "Fresh database with seeders",
        "optimize": "Optimize application performance"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "support": {
        "email": "support@security-platform.com",
        "issues": "https://github.com/security-platform/assessment/issues",
        "wiki": "https://github.com/security-platform/assessment/wiki"
    },
    "keywords": [
        "security",
        "assessment",
        "vulnerability-scanner",
        "rbac",
        "jwt",
        "audit",
        "compliance",
        "iso-27001",
        "nist",
        "cve"
    ]
}